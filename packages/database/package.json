{
  "name": "@repo/database",
  "version": "1.0.0",
  "description": "Shared utilities & libs",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio --verbose",
    "db:push": "drizzle-kit push",
    "gen:docs": "typedoc --out typedocs",
    "check:lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings 1000",
    "fix:lint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --fix --max-warnings=1000",
    "check:types": "tsc --noEmit --listFiles",
    "clean": "rm -rf node_modules dist .turbo && echo 'Cleanup complete!'"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "@repo/constants": "workspace:*",
    "pg": "^8.22.0"
  },
  "license": "ISC"
}
