{
  "name": "crisis-desk-ai",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:pkg": "pnpm --filter \"./packages/**\" run build",
    "dev": "turbo run dev",
    "check:lint": "turbo run check:lint",
    "fix:lint": "turbo run fix:lint",
    "check:types": "turbo run check:types",
    "format": "prettier --write \"**/*.{ts,md,json}\"",
    "check-types": "turbo run check-types",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "gen:docs": "typedoc",
    "gen:docs-all": "pnpm --if-present -r run gen:docs",
    "clean": "turbo run clean && rm -rf node_modules dist .turbo && echo 'Root Cleanup complete!'",
    "prepare": "husky",
    "commit": "cz"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@commitlint/cz-commitlint": "^21.2.0",
    "@commitlint/prompt-cli": "^21.2.0",
    "@commitlint/types": "^21.2.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "@types/request-ip": "^0.0.41",
    "commitizen": "^4.3.2",
    "commitlint-plugin-tense": "^1.0.10",
    "conventional-changelog-conventionalcommits": "^10.2.1",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "inquirer": "^14.0.2",
    "prettier": "^3.7.4",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "turbo": "^2.10.4",
    "typedoc": "^0.28.20",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/groq": "^4.0.8",
    "@aws-sdk/client-ssm": "^3.1090.0",
    "@langchain/core": "^1.2.3",
    "@langchain/mongodb": "^1.3.0",
    "@langchain/textsplitters": "^1.0.1",
    "@repo/constants": "workspace:*",
    "@repo/shared": "workspace:*",
    "@repo/zod": "workspace:*",
    "ai": "^7.0.22",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.5.0",
    "pg": "^8.22.0",
    "redis": "^6.1.0",
    "request-ip": "^3.3.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "packageManager": "pnpm@11.0.0",
  "engines": {
    "node": ">=18"
  }
}
